# Section 3 Performance Metrics for Binary Classification 
# Obtain predicted probabilities from logistic regression model 
pred <- predict(log.model, newdata = dat, type = "response")
# Predict class 1 if estimated probability > 0.5
class.pred <- 1*(pred > 0.5)
# Construct truth table 
tTable <- table(dat$y, class.pred)
tTable

# Section 3.2 Core performance metrics
# Function to calculate all metrics ( precision, recall, accuracy etc)
calculate_metrics <- function(conf_matrix) {
  # Basic counts
  TP <- conf_matrix[2,2]
  TN <- conf_matrix[1,1]
  FP <- conf_matrix[1,2]
  FN <- conf_matrix[2,1]
  
  # Caculate metrics 
  # Proportion of correct predictions 
  accuracy <- (TP + TN)/(TP +TN + FP + FN)
  # When we predict class 1, how ofted are we right? 
  precision <- (TP)/(TP + FP)
  # Of all actual class 1, how many did we catch? 
  recall <- (TP)/(TP + FN)
  # Of all actual class 0, how many did we identify correctly? 
  specificity <- (TN)/(TN + FP)
  # Harmonic mean of precision and recall 
  f1_score <- 2* (precision *recall)/(precision + recall)
  
  # Create vector with all metrics
  metrics <- data.frame("accuracy" = accuracy, 
                        "precision" = precision,
                        "recall" = recall, 
                        "specificitu" = specificity,
                        "f1_score" = f1_score)
  
  # Return all metrics 
  return(metrics)
}

# Calculate and display metrics 
metrics <- calculate_metrics(tTable)
metrics

# Section 3.3.2 Impact of threshold on trade-offs 
