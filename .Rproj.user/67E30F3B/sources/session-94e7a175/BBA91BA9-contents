# Section 3.4 The ROC curve 
# Install pROC package
install.packages('pROC')
library(pROC)
# Estimate ROC curve and plot it 
roc1 <- roc(dat$y, pred, plot=TRUE, grid=TRUE, col="red")

# Section 3.4.1 Extracting sensitivity and specificity 
# coords(): takes as input:
# 1. a ROC object (roc1)
# 2. 'x=' specifies the value of the objective we are interested in ( 0.8 specificity)
# 3. 'input=', specifies what this objective is 
# 4. 'ret=' specifies what output we want 
# (by default, threshold, specificity, and sensitivity are returned)
coords(roc1, x=0.8, input = "sensitivity")
# I can also ask to output all of the information requred to make the truth table 
r <- c("threshold", "specificity", "sensitivity", "accuracy", "tp", "tn", "fp", "fn")
coords(roc1, x=0.8, input = "sensitivity", ret = r)

# Section 3.4.2 Request specific values of sensitivity and specificity 
# you may request metrics for a specificity value that no threshold can achieve it
# in that case, the coords() function average the results from the two values that are closest 
# For example, to attain a 0.7 specificity 
coords(roc1, x=0.7, input = "specificity", ret = r)
# Notice how the output has a threhhold of NA 
# If we look at the specificity values listed in roc1, 
# we will see that there is no 0.7, instead there is a 0.696 and 0.704
roc1$specificities
# this means that a sensitivity of 0.7 cannot be achieved with any threshold
# remember how the roc curve shows you the different trade offs for sens and spec by changing the thresholds 
coords(roc1, x=0.704, input = "specificity", ret = r)

# Section 3.5 Classifier comparison based on ROC curves 
# fit model containing only x1 (one predictor variable)
m2 <- glm(y~x1, data = dat, family = binomial)
# Obtain estimated probabilities 
pred.m2 <- predict(m2, newdata = dat, type = "response")
# Estimate and plot ROC curve 
roc2 <- roc(dat$y, pred.m2, plot=TRUE, grid = TRUE, col = "blue")
# Add previous ROC curve to plot 
plot(roc1, add = TRUE, col = "red")
# Fit model containing only the intercept
null.model <- glm(y~1, data=dat, family=binomial)
pred.null <- predict(null.model, newdata = dat, type = "response")
# Estimate and plot ROC curve
roc3 <- roc(dat$y, pred.null, plot = TRUE, grid = TRUE, col ="black")
# Add previous 2 ROC curves to plot
plot(roc1, add = TRUE, col = "red")
plot(roc2, add = TRUE, col = "blue")
# The diagonal curve is because it is using the intercet, a constant, to make prediciton 
# so there is a equal possibility of assigning observations to either class, making a straight diagonal curve

# Section 3.6 Area under the ROC curve
# Area under ROC curve
auc(roc1)
# in case we do not have a sensitivity or specificity goal, 
# we can look at the threshold corresponding to the point to the top left corner or the ROC curve
# as this would be the point closes to the ideal classifier
# if x='best', we look for coordinates of the best method 
# best.method defines the optimizer that is used 
# "closest.topleft" optimizes on both specificity and sensitivity 
opt <- coords(roc1, x='best', best.method='closest.topleft', ret=r)
# Re=plot the ROC curve
plot(roc1, col='red', grid = TRUE)
# Add point in ROC curve that represent optimal trade-off
lines(opt["specificity"], opt["sensitivity"], type="p")



