# Section 5 - Model complexity and overfitting 
# degrees of polynomials of x1
degrees <- c(1:9)
# used to store values of log-likelihood (of training data) 
log.L <- rep(0,length(degrees))
# stores misclassification error 
error <- rep(0,length(degrees))

for (d in degrees) {
  # fit logistic regression with polynomial term predictors 
  logr <- glm(y~poly(x1,d)+x2, data = dat, family = binomial)
  # model fit quantified by log-likelyhood
  log.L[d] <- logLik(logr)
  
  # Compute classification and error on train set 
  train.class <- 1*(predict(logr, type = "response") > 0.5)
  error[d] <- mean(train.class != dat$y)
  
  # plot data and decision boundary 
  cpred <- 1*(predict(logr, newdata = Xtest, type = "response") >0.5)
  plot(Xtest[,1], Xtest[,2], cex = 0.1, col = cols[cpred+1], 
       main = paste("Decision Boundary for Polynomial of dregree", d), 
       xlab = "X_1", ylab = "X_2")
  points(x2~x1, data = dat, type = "p", col = cols[dat$y+1], pch = 16)
}
# Creating log likelihood plot
plot(log.L, type="b", ylab="log Likelihood",
     xlab="polynomial degree/ model complexity",
     main="log(Likelihood) on training data")
# causes x axis to have "ticks" at every integer
axis(1,1:max(degrees))
# Creating missclassification plot
plot(error, type="b", ylab="Error",
     xlab="polynomial degree/ model complexity",
     main="Error rate on training data")
axis(1,1:max(degrees))



# Section 6 Information cireteria and model/variable selection 
degrees <- 1:9
# initialize vectors to store aic, bic, log-l 
aic <- rep(0, max(degrees))
bic <- aic
log.l <- aic
for (d in degrees) {
  logR <- glm(y~poly(x1,d) + x2, data = dat, family = binomial)
  
  # Compute and store log-likelihood and information criteria
  log.l[d] <- -2*logLik(logR)
  aic[d] <- AIC(logR)
  bic[d] <- BIC(logR)
}

plot(log.l, type="b",
     main="information criteria for model selection",
     ylab="(penalised) log-likelihood",
     xlab="polynomial degree/ model complexity",
     ylim=c(min(log.l), max(bic)))
lines(aic, type = "b", col= "blue")
lines(bic, type = "b", col= "red")
# labels/ ticks at every integer on horizontal axis
axis(1,1:9)
# add legend to improve readability
legend("bottomleft", c("-2*logl","aic", "bic"),
       col = c("black", "blue", "red"),
       pch = c(1,1,1), lty = c(1,1,1))
# Model selected by AIC
which.min(aic)
# Model selected by BIC
which.min(bic)
#Plot models selected by the two criteria
# using lty (`l`ine`ty`pe) =2 I get dashed lines
abline(h = min(aic), col = "red", lty = 2)
abline(h = min(bic), col = "blue", lty = 2)  
  
  
  
  
  
