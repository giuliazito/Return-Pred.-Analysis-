# Q8. At what months and miles do the top makes/models expenses in --------

fuel_total <- fuel %>%
  group_by(VEHICLE_ID) %>%
  summarise(TOTAL_FUEL = sum(AMOUNT, na.rm = TRUE))

maint_total <- maint %>%
  group_by(VEHICLE_ID) %>%
  summarise(TOTAL_MAINT = sum(COST, na.rm = TRUE))

q8_data <- assets %>%
  mutate(IN_SERVICE_DATE = ymd(IN_SERVICE_DATE),
         MONTHS_IN_SERVICE = interval(IN_SERVICE_DATE, ymd(Sys.Date())) %/% months(1),
         AGE_BIN = cut(MONTHS_IN_SERVICE, breaks = seq(84, 180, by = 12))) %>%
  left_join(fuel_total, by = "VEHICLE_ID") %>%
  left_join(maint_total, by = "VEHICLE_ID") %>%
  replace_na(list(TOTAL_FUEL = 0, TOTAL_MAINT = 0)) %>%
  mutate(TOTAL_EXPENSES = TOTAL_FUEL + TOTAL_MAINT)

top_10_models <- c("F-150", "SILVERADO", "FOCUS", "TACOMA", "F-350")

q8_summary <- q8_data %>%
  filter(MODEL %in% top_10_models) %>%
  group_by(MODEL, AGE_BIN) %>%
  summarise(MEDIAN_EXPENSES = median(TOTAL_EXPENSES, na.rm = TRUE),
            MEDIAN_ODOMETER = median(CURRENT_ODOM, na.rm = TRUE),
            .groups = "drop") %>%
  mutate(EXPENSE_BIN = cut(MEDIAN_EXPENSES, 
                           breaks = c(-Inf, 1500, 3000, Inf), 
                           labels = c("< $1.5K", "$1.5K-$3K", "> $3K"),
                           right = TRUE))


label_data <- q8_summary %>%
  mutate(AGE_BIN = as.character(AGE_BIN)) %>%
  filter(
    (MODEL == "TACOMA" & AGE_BIN == "(96,108]") |
     (MODEL == "F-150" & AGE_BIN == "(108,120]") |
     (MODEL == "SILVERADO" & AGE_BIN == "(132,144]") |
     (MODEL == "FOCUS" & AGE_BIN == "(120,132]") |
    (MODEL == "F-350" & AGE_BIN == "(144,156]")
  ) %>%
  mutate(
    hjust = case_when(
      MODEL == "TACOMA" ~ 0.2,
      MODEL == "F-150" ~ 0.2,
      MODEL == "SILVERADO" ~ 0.20,
      MODEL == "FOCUS" ~ 0.70,
      MODEL == "F-350" ~ 0.10
    ),
    vjust = case_when(
      MODEL == "TACOMA" ~ 2,
      MODEL == "F-150" ~ 3.3,
      MODEL == "SILVERADO" ~ 1.8,
      MODEL == "FOCUS" ~ 2.5,
      MODEL == "F-350" ~ 2.5
    )
  )

q8_summary %>% 
ggplot(aes(y = AGE_BIN, x = MEDIAN_ODOMETER, 
                       size = EXPENSE_BIN, color = MODEL)) +
  geom_point(alpha = 0.7) +
  geom_text(data = label_data, 
            aes(label = MODEL, color = MODEL, hjust = hjust, vjust = vjust),
            size = 4, show.legend = FALSE, fontface = "bold") +
  scale_x_continuous(labels = label_number(suffix = "K", scale = 1e-3)) +
  scale_y_discrete(labels = c(
    "(84,96]" = "85-96",
    "(96,108]" = "97-108",
    "(108,120]" = "109-120",
    "(120,132]" = "121-132",
    "(132,144]" = "133-144",
    "(144,156]" = "145-156",
    "(156,168]" = "157-168"
  )) +
  scale_color_manual(values = c("TACOMA" = "#33a02c", 
                                "F-150" = "#6a3d9a", 
                                "FOCUS" = "#ff7f00", 
                                "SILVERADO" =  "#e31a1c", 
                                "F-350" = "#1f78b4"), guide = "none") +
  #scale_color_brewer(palette="Paired") +
  scale_size_manual(values = c("< $1.5K" = 2, "$1.5K-$3K" = 6, "> $3K" = 10),
                    name = "Median Expenses") +
  labs(
    title = "At What Months and Miles Do Expenses Increase?",
    y = "Months in Service",
    x = "Median Odometer (Miles)",
    color = "Model") +
  guides(color = "none",
         size = guide_legend()) +
  theme_minimal() +
  theme(
    legend.position = c(0.8, 0.2),
    panel.grid.minor = element_blank(),
    title = element_text(face = "bold", size = 13),
    axis.text.y = element_text(face = "bold", color = "black", size = 10),
    axis.text.x = element_text(face = "bold", color = "black", size = 10)
  )

