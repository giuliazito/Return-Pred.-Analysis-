# Q7. Typical Number of repair orders, repair items, and their cos --------

asset_monthly_bins <- assets %>%
  mutate(IN_SERVICE_DATE = ymd(IN_SERVICE_DATE),
         MONTHS_IN_SERVICE = interval(IN_SERVICE_DATE, ymd(Sys.Date())) %/% months(1),
         # Create 12-month bins (0-12, 13-24, etc.)
         AGE_BIN = cut(MONTHS_IN_SERVICE, 
                       breaks = seq(84, 180, by = 12), 
                       labels = c("85-96", "97-108", "109-120", "121-132", 
                                  "133-144", "145-156", "157-168", "169-180")))

maint_rep_summary <- maint %>%
  group_by(VEHICLE_ID) %>%
  summarise(REPAIR_ORDERS = n_distinct(REPAIR_ORDER_NO),
            REPAIR_ITEMS = n(),
            REPAIR_COST = sum(COST, na.rm = TRUE))

final_maint_summary <- asset_monthly_bins %>%
  left_join(maint_rep_summary, by = "VEHICLE_ID") %>%
  mutate(REPAIR_ORDERS = replace_na(REPAIR_ORDERS, 0),
         REPAIR_ITEMS = replace_na(REPAIR_ITEMS, 0),
         REPAIR_COST = replace_na(REPAIR_COST, 0))


install.packages("ggridges")
