# Q6. Top 5 Make and Models with highest monthly cost  --------------------

Total_fuel_cost <- fuel %>%
  group_by(VEHICLE_ID) %>%
  summarise(TOTAL_FUEL = sum(AMOUNT, na.rm = TRUE)/ 4) 

Total_maint_cost <- maint %>%
  group_by(VEHICLE_ID) %>%
  summarize(TOTAL_MAINT = sum(COST, na.rm = TRUE)/ 10)

total_costs <- assets %>%
  left_join(Total_fuel_cost, by = "VEHICLE_ID") %>%
  left_join(Total_maint_cost, by = "VEHICLE_ID") %>%
  mutate(across(c(TOTAL_FUEL, TOTAL_MAINT), ~replace_na(., 0))) %>%
  mutate(TOTAL_OPR_COST = TOTAL_FUEL + TOTAL_MAINT)

top_5_monthly_costs <- total_costs %>%
  mutate(MAKE_MODEL = paste(MAKE, MODEL, sep = ": ")) %>%
  group_by(MAKE_MODEL) %>%
  summarise(MONTHLY_COST = median(TOTAL_OPR_COST, na.rm = TRUE)) %>%
  slice_max(order_by = MONTHLY_COST, n=5)

top_5_monthly_costs %>%
  ggplot(aes(x=reorder(MAKE_MODEL, -MONTHLY_COST), y = MONTHLY_COST, fill = MAKE_MODEL)) +
  geom_col() +
  scale_fill_brewer(palette = "Paired") +
  scale_y_continuous(labels = label_dollar()) +
  labs(title = "Top 5 Make/Models with Highest Monthly Cost",
       x = "", 
       y = "") +
  theme_minimal() +
  theme(
    legend.position = "none",
    panel.grid.minor = element_blank(),
    plot.title = element_text(face = "bold", size = 15),
    axis.text.x = element_text(color = "black", size = 10),
    axis.text.y = element_text(color = "black", size = 11)
  )
  
