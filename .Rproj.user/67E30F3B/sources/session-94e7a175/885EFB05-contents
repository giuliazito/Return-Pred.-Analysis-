install.packages("tidyverse")
library(tidyverse)
install.packages("scales")
library(scales)

assets <- read_csv("assets.csv")
fuel <- read_csv("fuel.csv")
maint <- read_csv("maintenance.csv")


# Q1 Top 10 Make/Models  --------------------------------------------------

asset_count <- assets %>%
  mutate(MAKE_MODEL = paste(MAKE, MODEL, sep = ": ")) %>%
  group_by(MAKE_MODEL) %>%
  summarise(asset_count = n(), .groups = "drop") %>%
  slice_max(order_by = asset_count, n=10)

asset_count %>%
  ggplot(aes(y = fct_reorder(MAKE_MODEL, asset_count), x = asset_count, 
             fill = MAKE_MODEL)) +
  geom_col() +
  labs(title = "Top 10 Assets ",
       x = "Asset Count", 
       y = "") +
  scale_fill_brewer(palette = "Paired") +
  theme_minimal() +
  theme(
    legend.position = "none",
    panel.grid.minor = element_blank()
  )


# Q2. Assets by age and odometer  -----------------------------------------

asset_cleaned <- assets %>%
  # Standardize the date format
  mutate(IN_SERVICE_DATE = ymd(IN_SERVICE_DATE)) %>%
  # Calculate full months between the service date and today
  mutate(MONTHS_IN_SERVICE = interval(IN_SERVICE_DATE, ymd(Sys.Date())) %/% months(1),
         ODOMETER_BIN = floor(CURRENT_ODOM / 5000) * 5000)

asset_count <- asset_cleaned %>%
  filter(ODOMETER_BIN > 0, MONTHS_IN_SERVICE > 0) %>%
  group_by(ODOMETER_BIN, MONTHS_IN_SERVICE) %>%
  summarize(asset_count = n())

asset_count %>%
  filter(!is.na(ODOMETER_BIN)) %>%
    ggplot(aes(y = ODOMETER_BIN, x = MONTHS_IN_SERVICE, color = asset_count)) +
  geom_jitter(alpha = 1, width = 0.2) +
  scale_color_viridis_c(option = "turbo") +
  scale_y_continuous(
    breaks = seq(0, max(asset_cleaned$ODOMETER_BIN, na.rm = TRUE), by = 200000),
    labels = label_number(suffix = "K", scale = 1e-3) 
  ) +
  guides(color = guide_legend(override.aes = list(alpha = 1, size = 4))) +
  labs(title = "Assets Count by Age and Odometer", 
       x = "Months In Service", 
       y = "Odometer in Miles") +
  theme_minimal() +
  theme(
    legend.title = element_blank(),
    panel.grid.minor = element_blank()
  ) +
  coord_cartesian(ylim = c(0, 400000))
  

